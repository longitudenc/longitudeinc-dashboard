# Authentication
NEXTAUTH_URL=https://longitudeinc.net
NEXTAUTH_SECRET=                          # generate with: openssl rand -base64 32

# Google OAuth (for AM/admin login)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Resend (for magic link emails)
RESEND_API_KEY=
RESEND_FROM_EMAIL=noreply@longitudeinc.net

# Supabase (database)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Google Sheets (existing data source — used during migration)
GOOGLE_SHEETS_ID=                         # your database spreadsheet ID
GOOGLE_SERVICE_ACCOUNT_EMAIL=
GOOGLE_SERVICE_ACCOUNT_PRIVATE_KEY=

# Magic link token expiry (seconds)
MAGIC_LINK_EXPIRY=3600
